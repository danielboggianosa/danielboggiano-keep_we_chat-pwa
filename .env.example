# =============================================================================
# Meeting Transcription System — Environment Variables
# Copy this file to .env and fill in the values before running docker-compose.
# =============================================================================

# --- General ---
NODE_ENV=development

# --- PostgreSQL ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=meeting_transcription
POSTGRES_PORT=5432
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/meeting_transcription

# --- MinIO / S3 Object Storage ---
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# --- API Gateway ---
API_GATEWAY_PORT=4000
JWT_SECRET=change-me-to-a-random-secret

# --- Zoom Integration ---
ZOOM_API_KEY=
ZOOM_API_SECRET=

# --- Google Calendar OAuth ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Microsoft Teams OAuth ---
TEAMS_CLIENT_ID=
TEAMS_CLIENT_SECRET=

# --- STT Cloud Service ---
STT_CLOUD_PORT=4001
STT_MODEL_PATH=/models/whisper-large

# --- NLP Service ---
NLP_SERVICE_PORT=4002
NLP_MODEL_NAME=gpt-4

# --- Search Service ---
SEARCH_SERVICE_PORT=4003

# --- Calendar Service ---
CALENDAR_SERVICE_PORT=4004

# --- Client PWA ---
CLIENT_PORT=3000
