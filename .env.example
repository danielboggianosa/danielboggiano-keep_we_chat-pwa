# =============================================================================
# Meeting Transcription System — Environment Variables
# Copy this file to .env and fill in the values before running docker-compose.
# =============================================================================

# --- General ---
NODE_ENV=development
LOG_LEVEL=info                # info | debug | warn | error

# --- PostgreSQL ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=meeting_transcription
POSTGRES_PORT=5432
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/meeting_transcription

# --- MinIO / S3 Object Storage ---
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# --- API Gateway ---
API_GATEWAY_PORT=4000
JWT_SECRET=change-me-to-a-random-secret       # REQUIRED — used to sign/verify JWT tokens
ALLOWED_ORIGINS=http://localhost:3000          # Comma-separated list of allowed CORS origins

# --- Zoom Integration (optional) ---
ZOOM_API_KEY=
ZOOM_API_SECRET=

# --- Google Calendar OAuth ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/
VITE_GOOGLE_CLIENT_ID=
GOOGLE_REDIRECT_URI=http://localhost:4004/callback/google-calendar

# --- Microsoft Teams / Azure OAuth ---
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_REDIRECT_URI=http://localhost:4004/callback/teams-calendar
AZURE_TENANT_ID=common

# --- Calendar Service ---
CALENDAR_SERVICE_PORT=4004
TOKEN_ENCRYPTION_KEY=change-me-to-a-random-key  # REQUIRED — used to encrypt OAuth tokens at rest
APP_URL=http://localhost:3000                    # Redirect URL after OAuth callback

# --- STT Cloud Service ---
STT_CLOUD_PORT=4001
STT_MODEL_PATH=/models/whisper-large
WHISPER_MODEL=base                               # Whisper model size: tiny | base | small | medium | large

# --- NLP Service ---
NLP_SERVICE_PORT=4002
NLP_MODEL=gpt-4                                  # OpenAI model name
OPENAI_API_KEY=                                  # REQUIRED for NLP service

# --- Search Service ---
SEARCH_SERVICE_PORT=4003

# --- Client PWA ---
CLIENT_PORT=3000

# --- Prometheus ---
PROMETHEUS_PORT=9090
